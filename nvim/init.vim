set notermguicolors

highlight Normal      ctermfg=7  ctermbg=0  " White on Black (7: white, 0: black)
highlight Comment     ctermfg=2  ctermbg=NONE " Green comments
highlight Constant    ctermfg=1  ctermbg=NONE " Red constants
highlight Identifier  ctermfg=4  ctermbg=NONE " Blue identifiers
highlight Statement   ctermfg=5  ctermbg=NONE " Purple statements
highlight PreProc     ctermfg=3  ctermbg=NONE " Yellow preprocessor
highlight Type        ctermfg=6  ctermbg=NONE " Cyan types